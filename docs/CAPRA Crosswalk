<script>
// ── Toggle standard open/close ──
function toggle(header) {
  const body = header.nextElementSibling;
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  header.setAttribute('aria-expanded', !isOpen);
}

// ── Expand all checkbox ──
document.getElementById('expand-all').addEventListener('change', function() {
  document.querySelectorAll('.standard-body').forEach(b => {
    b.classList.toggle('open', this.checked);
  });
  document.querySelectorAll('.standard-header').forEach(h => {
    h.setAttribute('aria-expanded', this.checked);
  });
});

// ── Fundamental only filter ──
document.getElementById('fund-only').addEventListener('change', function() {
  document.querySelectorAll('.standard').forEach(s => {
    const isFund = s.dataset.fund === 'true';
    s.classList.toggle('hidden', this.checked && !isFund);
  });
  updateCount();
});

// ── Search ──
document.getElementById('search').addEventListener('input', function() {
  const q = this.value.toLowerCase().trim();
  document.querySelectorAll('.standard').forEach(s => {
    if (!q) { s.classList.remove('hidden'); return; }
    const text = s.textContent.toLowerCase();
    const match = text.includes(q);
    s.classList.toggle('hidden', !match);
    if (match && q) {
      s.querySelector('.standard-body').classList.add('open');
      s.querySelector('.standard-header').setAttribute('aria-expanded', true);
    }
  });
  updateCount();
});

function updateCount() {
  const visible = document.querySelectorAll('.standard:not(.hidden)').length;
  const total = document.querySelectorAll('.standard').length;
  const el = document.getElementById('search-count');
  el.textContent = visible < total ? `Showing ${visible} of ${total} standards` : `${total} standards`;
}

// ── Active nav highlight on scroll ──
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('nav a[data-section]');

const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      navLinks.forEach(a => a.classList.toggle('active', a.dataset.section === entry.target.id));
    }
  });
}, { rootMargin: '-30% 0px -65% 0px' });

sections.forEach(s => observer.observe(s));

// ── Smooth scroll for nav links ──
navLinks.forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    const target = document.getElementById(a.dataset.section);
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
});

updateCount();
</script>
