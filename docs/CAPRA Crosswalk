const STATUS = { "": "Not Started", "gap": "Gap / Missing", "partial": "Partial", "complete": "Complete" };
const STATUS_COLORS = { "": "#e5e7eb", "gap": "#fee2e2", "partial": "#fef3c7", "complete": "#dcfce7" };
const STATUS_TEXT = { "": "#6b7280", "gap": "#dc2626", "partial": "#d97706", "complete": "#16a34a" };
const CHANGE_COLORS = { "1:1": { bg: "#dbeafe", text: "#1e40af" }, "ELEVATED": { bg: "#ede9fe", text: "#5b21b6" }, "MERGED": { bg: "#fef3c7", text: "#92400e" }, "EXPANDED": { bg: "#f3f4f6", text: "#374151" }, "NEW": { bg: "#dcfce7", text: "#166534" } };
const CH_NAMES = { 1: "Mission & Purpose", 2: "Administration", 3: "Park Planning", 4: "Human Resources", 5: "Finance", 6: "Programs", 7: "Facilities", 8: "Risk & Safety", 9: "Marketing", 10: "Evaluation" };

export default function App() {
  const [scores, setScores] = useState({});
  const [notes, setNotes] = useState({});
  const [selected, setSelected] = useState(null);
  const [filterCh, setFilterCh] = useState(0);
  const [filterStatus, setFilterStatus] = useState("");
  const [filterFund, setFilterFund] = useState("all");
  const [view, setView] = useState("grid");

  const key = (stdNum, qi) => `${stdNum}__${qi}`;

  const getStdStatus = (std) => {
    const answers = std.rubric.map((_, i) => scores[key(std.new, i)] || "");
    if (answers.every(a => a === "")) return "";
    if (answers.some(a => a === "gap")) return "gap";
    if (answers.every(a => a === "complete")) return "complete";
    return "partial";
  };

  const filtered = useMemo(() => standards.filter(s => {
    if (filterCh && s.ch !== filterCh) return false;
    if (filterStatus !== "" && getStdStatus(s) !== filterStatus) return false;
    if (filterFund === "fund" && !s.fundamental) return false;
    if (filterFund === "nonfund" && s.fundamental) return false;
    return true;
  }), [scores, filterCh, filterStatus, filterFund]);

  const summary = useMemo(() => {
    const r = { total: standards.length, complete: 0, partial: 0, gap: 0, notStarted: 0 };
    standards.forEach(s => {
      const st = getStdStatus(s);
      if (st === "complete") r.complete++;
      else if (st === "partial") r.partial++;
      else if (st === "gap") r.gap++;
      else r.notStarted++;
    });
    return r;
  }, [scores]);

  const pct = Math.round((summary.complete / summary.total) * 100);

  const selStd = selected ? standards.find(s => s.new === selected) : null;

  return (
    <div style={{ fontFamily: "system-ui, sans-serif", maxWidth: 1100, margin: "0 auto", padding: 16, fontSize: 13 }}>
      <div style={{ background: "#1e3a5f", color: "white", borderRadius: 10, padding: "16px 22px", marginBottom: 14 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", flexWrap: "wrap", gap: 10 }}>
          <div>
            <h1 style={{ margin: 0, fontSize: 18, fontWeight: 700 }}>CAPRA 2027 Standards – Compliance Evaluator</h1>
            <p style={{ margin: "3px 0 0", opacity: 0.8, fontSize: 12 }}>Rate each rubric question · track gaps · transition from 154 → 67 standards</p>
          </div>
          <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
            <div style={{ textAlign: "center" }}>
              <div style={{ fontSize: 24, fontWeight: 800 }}>{pct}%</div>
              <div style={{ fontSize: 11, opacity: 0.7 }}>Complete</div>
            </div>
          </div>
        </div>
        <div style={{ display: "flex", gap: 6, marginTop: 12, flexWrap: "wrap" }}>
          {[["complete", "#16a34a", summary.complete], ["partial", "#d97706", summary.partial], ["gap", "#dc2626", summary.gap], ["notStarted", "#9ca3af", summary.notStarted]].map(([k, c, v]) => (
            <div key={k} style={{ background: "rgba(255,255,255,0.15)", borderRadius: 6, padding: "4px 12px", fontSize: 12 }}>
              <span style={{ color: c, fontWeight: 700 }}>●</span> {k === "notStarted" ? "Not Started" : k.charAt(0).toUpperCase() + k.slice(1)}: <strong>{v}</strong>
            </div>
          ))}
        </div>
        <div style={{ marginTop: 10, background: "rgba(255,255,255,0.2)", borderRadius: 4, height: 8 }}>
          <div style={{ background: "#4ade80", borderRadius: 4, height: 8, width: `${pct}%`, transition: "width 0.3s" }} />
        </div>
      </div>

      {/* Filters */}
      <div style={{ display: "flex", gap: 8, marginBottom: 12, flexWrap: "wrap", alignItems: "center" }}>
        <select value={filterCh} onChange={e => setFilterCh(+e.target.value)} style={{ padding: "6px 10px", borderRadius: 6, border: "1px solid #d1d5db", fontSize: 12 }}>
          <option value={0}>All Chapters</option>
          {Object.entries(CH_NAMES).map(([k, v]) => <option key={k} value={k}>Ch. {k}: {v}</option>)}
        </select>
        <select value={filterStatus} onChange={e => setFilterStatus(e.target.value)} style={{ padding: "6px 10px", borderRadius: 6, border: "1px solid #d1d5db", fontSize: 12 }}>
          <option value="">All Statuses</option>
          {Object.entries(STATUS).map(([k, v]) => <option key={k} value={k}>{v}</option>)}
        </select>
        <select value={filterFund} onChange={e => setFilterFund(e.target.value)} style={{ padding: "6px 10px", borderRadius: 6, border: "1px solid #d1d5db", fontSize: 12 }}>
          <option value="all">All Standards</option>
          <option value="fund">Fundamental Only</option>
          <option value="nonfund">Non-Fundamental Only</option>
        </select>
        <div style={{ marginLeft: "auto", display: "flex", gap: 4 }}>
          {["grid", "list"].map(v => (
            <button key={v} onClick={() => setView(v)} style={{ padding: "5px 12px", borderRadius: 5, border: "none", cursor: "pointer", background: view === v ? "#1e3a5f" : "#e5e7eb", color: view === v ? "white" : "#374151", fontWeight: 600, fontSize: 12 }}>{v === "grid" ? "⊞ Grid" : "≡ List"}</button>
          ))}
        </div>
        <span style={{ color: "#6b7280", fontSize: 12 }}>{filtered.length} shown</span>
      </div>

      {/* Grid or List */}
      {!selStd && view === "grid" && (
        <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(200px, 1fr))", gap: 10 }}>
          {filtered.map(s => {
            const st = getStdStatus(s);
            const ct = CHANGE_COLORS[s.changeType];
            const answered = s.rubric.filter((_, i) => scores[key(s.new, i)] && scores[key(s.new, i)] !== "").length;
            return (
              <div key={s.new} onClick={() => setSelected(s.new)} style={{ background: STATUS_COLORS[st], borderRadius: 8, padding: 12, cursor: "pointer", border: "1px solid #e5e7eb", transition: "box-shadow 0.15s" }}
                onMouseEnter={e => e.currentTarget.style.boxShadow = "0 2px 8px rgba(0,0,0,0.15)"}
                onMouseLeave={e => e.currentTarget.style.boxShadow = "none"}>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
                  <span style={{ fontWeight: 800, color: "#1e3a5f", fontSize: 15 }}>{s.new}</span>
                  {s.fundamental && <span style={{ background: "#1e3a5f", color: "white", borderRadius: 10, padding: "1px 7px", fontSize: 10, fontWeight: 700 }}>F</span>}
                </div>
                <div style={{ fontWeight: 600, fontSize: 12, marginTop: 4, lineHeight: 1.4, color: "#111827" }}>{s.newTitle}</div>
                <div style={{ display: "flex", gap: 5, marginTop: 8, alignItems: "center", flexWrap: "wrap" }}>
                  <span style={{ background: ct.bg, color: ct.text, borderRadius: 10, padding: "2px 7px", fontSize: 10, fontWeight: 700 }}>{s.changeType}</span>
                  <span style={{ color: STATUS_TEXT[st], fontSize: 11, fontWeight: 600 }}>{answered}/{s.rubric.length} ✓</span>
                </div>
              </div>
            );
          })}
        </div>
      )}

      {!selStd && view === "list" && (
        <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12 }}>
          <thead>
            <tr style={{ background: "#f3f4f6" }}>
              {["#", "Title", "F", "Change", "Old Standard(s)", "Status", "Progress"].map(h => (
                <th key={h} style={{ padding: "8px 10px", textAlign: "left", borderBottom: "2px solid #d1d5db", fontWeight: 700, whiteSpace: "nowrap" }}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {filtered.map((s, i) => {
              const st = getStdStatus(s);
              const answered = s.rubric.filter((_, qi) => scores[key(s.new, qi)] && scores[key(s.new, qi)] !== "").length;
              const ct = CHANGE_COLORS[s.changeType];
              return (
                <tr key={s.new} onClick={() => setSelected(s.new)} style={{ background: i % 2 === 0 ? "white" : "#f9fafb", cursor: "pointer", borderBottom: "1px solid #e5e7eb" }}
                  onMouseEnter={e => e.currentTarget.style.background = "#eff6ff"}
                  onMouseLeave={e => e.currentTarget.style.background = i % 2 === 0 ? "white" : "#f9fafb"}>
                  <td style={{ padding: "8px 10px", fontWeight: 800, color: "#1e3a5f", whiteSpace: "nowrap" }}>{s.new}</td>
                  <td style={{ padding: "8px 10px", fontWeight: 500 }}>{s.newTitle}</td>
                  <td style={{ padding: "8px 10px", textAlign: "center" }}>{s.fundamental ? <span style={{ background: "#1e3a5f", color: "white", borderRadius: 10, padding: "1px 6px", fontSize: 10 }}>F</span> : ""}</td>
                  <td style={{ padding: "8px 10px" }}><span style={{ background: ct.bg, color: ct.text, borderRadius: 10, padding: "2px 8px", fontSize: 10, fontWeight: 700 }}>{s.changeType}</span></td>
                  <td style={{ padding: "8px 10px", color: "#6b7280", fontSize: 11 }}>{s.old}</td>
                  <td style={{ padding: "8px 10px" }}><span style={{ background: STATUS_COLORS[st], color: STATUS_TEXT[st], borderRadius: 10, padding: "2px 8px", fontWeight: 600, fontSize: 11 }}>{STATUS[st]}</span></td>
                  <td style={{ padding: "8px 10px", whiteSpace: "nowrap", color: "#6b7280" }}>{answered}/{s.rubric.length}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}

      {/* Detail Panel */}
      {selStd && (
        <div style={{ background: "white", border: "1px solid #d1d5db", borderRadius: 10, padding: 20 }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 16 }}>
            <div>
              <div style={{ display: "flex", gap: 8, alignItems: "center", flexWrap: "wrap" }}>
                <span style={{ fontWeight: 800, fontSize: 20, color: "#1e3a5f" }}>{selStd.new}</span>
                {selStd.fundamental && <span style={{ background: "#1e3a5f", color: "white", borderRadius: 10, padding: "2px 10px", fontSize: 11, fontWeight: 700 }}>FUNDAMENTAL</span>}
                <span style={{ background: CHANGE_COLORS[selStd.changeType].bg, color: CHANGE_COLORS[selStd.changeType].text, borderRadius: 10, padding: "2px 10px", fontSize: 11, fontWeight: 700 }}>{selStd.changeType}</span>
              </div>
              <h2 style={{ margin: "6px 0 4px", fontSize: 16, color: "#111827" }}>{selStd.newTitle}</h2>
              <div style={{ fontSize: 12, color: "#6b7280" }}>
                <span style={{ fontWeight: 600 }}>Previous standard(s):</span> {selStd.old} — {selStd.oldTitles}
              </div>
              <div style={{ fontSize: 12, color: "#6b7280", marginTop: 3 }}>
                <span style={{ fontWeight: 600 }}>Transition note:</span> {selStd.notes}
              </div>
            </div>
            <button onClick={() => setSelected(null)} style={{ padding: "6px 14px", borderRadius: 6, border: "none", cursor: "pointer", background: "#f3f4f6", fontWeight: 600, fontSize: 13 }}>← Back</button>
          </div>

          <div style={{ borderTop: "1px solid #e5e7eb", paddingTop: 16 }}>
            <h3 style={{ margin: "0 0 14px", fontSize: 14, color: "#374151" }}>Rubric Questions – Rate Your Compliance</h3>
            {selStd.rubric.map((q, qi) => {
              const k = key(selStd.new, qi);
              const s = scores[k] || "";
              return (
                <div key={qi} style={{ background: STATUS_COLORS[s], borderRadius: 8, padding: "12px 14px", marginBottom: 10, border: "1px solid #e5e7eb" }}>
                  <div style={{ fontWeight: 600, color: "#111827", marginBottom: 8, lineHeight: 1.5 }}>
                    <span style={{ color: "#6b7280", marginRight: 6 }}>Q{qi + 1}.</span>{q}
                  </div>
                  <div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
                    {Object.entries(STATUS).map(([v, label]) => (
                      <button key={v} onClick={() => setScores(prev => ({ ...prev, [k]: v }))}
                        style={{ padding: "4px 12px", borderRadius: 20, border: `2px solid ${s === v ? STATUS_TEXT[v] || "#9ca3af" : "#d1d5db"}`, cursor: "pointer", background: s === v ? (STATUS_COLORS[v] || "#f3f4f6") : "white", color: s === v ? (STATUS_TEXT[v] || "#6b7280") : "#6b7280", fontWeight: s === v ? 700 : 500, fontSize: 12 }}>
                        {label}
                      </button>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>

          <div style={{ marginTop: 16, borderTop: "1px solid #e5e7eb", paddingTop: 14 }}>
            <label style={{ fontWeight: 600, fontSize: 13, color: "#374151", display: "block", marginBottom: 6 }}>Agency Notes / Documentation References</label>
            <textarea value={notes[selStd.new] || ""} onChange={e => setNotes(prev => ({ ...prev, [selStd.new]: e.target.value }))}
              placeholder="Enter notes, documentation references, responsible staff, or transition action items..."
              style={{ width: "100%", minHeight: 80, padding: "8px 10px", borderRadius: 6, border: "1px solid #d1d5db", fontSize: 13, resize: "vertical", boxSizing: "border-box" }} />
          </div>

          {/* Nav between standards */}
          <div style={{ display: "flex", justifyContent: "space-between", marginTop: 14 }}>
            {(() => {
              const idx = filtered.findIndex(s => s.new === selStd.new);
              const prev = filtered[idx - 1];
              const next = filtered[idx + 1];
              return (
                <>
                  <button onClick={() => prev && setSelected(prev.new)} disabled={!prev}
                    style={{ padding: "6px 14px", borderRadius: 6, border: "none", cursor: prev ? "pointer" : "default", background: prev ? "#e5e7eb" : "#f9fafb", color: prev ? "#374151" : "#d1d5db", fontWeight: 600, fontSize: 12 }}>
                    ← {prev ? prev.new : ""}
                  </button>
                  <button onClick={() => next && setSelected(next.new)} disabled={!next}
                    style={{ padding: "6px 14px", borderRadius: 6, border: "none", cursor: next ? "pointer" : "default", background: next ? "#e5e7eb" : "#f9fafb", color: next ? "#374151" : "#d1d5db", fontWeight: 600, fontSize: 12 }}>
                    {next ? next.new : ""} →
                  </button>
                </>
              );
            })()}
          </div>
        </div>
      )}

      <p style={{ fontSize: 11, color: "#9ca3af", marginTop: 16 }}>
        Note: Ratings are stored in this browser session only. For persistent tracking, copy notes to an external document. F = Fundamental standard (all 37 must be met). Sources: CAPRA 2027 National Accreditation Standards (August 2025) and 2019/2023 Standards (154 standards).
      </p>
    </div>
  );
}
