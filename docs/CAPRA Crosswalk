<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CAPRA 2027 National Accreditation Standards</title>
<style>
  :root {
    --teal: #0e6b6b; --teal-light: #e6f4f4; --teal-dark: #084e4e;
    --gold: #c8952a; --gold-light: #fdf5e6;
    --gray-50: #f9fafb; --gray-100: #f3f4f6; --gray-200: #e5e7eb;
    --gray-400: #9ca3af; --gray-600: #4b5563; --gray-800: #1f2937;
    --fund-bg: #e6f4f4; --fund-border: #0e6b6b;
    --radius: 8px; --shadow: 0 1px 4px rgba(0,0,0,0.1);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; font-size: 15px; color: var(--gray-800); background: var(--gray-50); line-height: 1.6; }

  /* ── HEADER ── */
  header { background: var(--teal-dark); color: #fff; padding: 28px 24px 20px; }
  header h1 { font-size: 1.7rem; font-weight: 700; letter-spacing: -0.3px; }
  header p { opacity: .8; font-size: .9rem; margin-top: 4px; }
  .header-meta { display:flex; flex-wrap:wrap; gap:12px; margin-top:14px; }
  .badge { background: rgba(255,255,255,.15); border-radius:20px; padding:4px 14px; font-size:.82rem; }
  .badge strong { color:#7ff0c8; }

  /* ── NAV TABS ── */
  nav { background:#fff; border-bottom:2px solid var(--gray-200); position:sticky; top:0; z-index:100; overflow-x:auto; white-space:nowrap; }
  nav ul { display:flex; list-style:none; padding:0 16px; }
  nav ul li a { display:block; padding:12px 14px; font-size:.84rem; font-weight:600; color:var(--gray-600); text-decoration:none; border-bottom:3px solid transparent; transition:all .15s; }
  nav ul li a:hover { color:var(--teal); }
  nav ul li a.active { color:var(--teal); border-bottom-color:var(--teal); }

  /* ── SEARCH BAR ── */
  .search-bar { background:#fff; padding:12px 20px; border-bottom:1px solid var(--gray-200); display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
  .search-bar input { flex:1; min-width:220px; padding:8px 14px; border:1px solid var(--gray-200); border-radius:20px; font-size:.9rem; outline:none; }
  .search-bar input:focus { border-color:var(--teal); }
  .search-bar label { font-size:.83rem; color:var(--gray-600); display:flex; align-items:center; gap:5px; cursor:pointer; }
  #search-count { font-size:.82rem; color:var(--gray-400); margin-left:auto; }

  /* ── MAIN LAYOUT ── */
  main { max-width: 1100px; margin: 0 auto; padding: 20px 16px 60px; }

  /* ── CHAPTER SECTION ── */
  .chapter { margin-bottom: 40px; }
  .chapter-header { background: var(--teal); color: #fff; border-radius: var(--radius) var(--radius) 0 0; padding: 14px 20px; }
  .chapter-header h2 { font-size: 1.1rem; font-weight: 700; }
  .chapter-intro { background: var(--teal-light); border: 1px solid var(--teal); border-top: none; padding: 14px 20px; font-size: .88rem; color: var(--teal-dark); line-height: 1.65; }
  .chapter-intro details summary { font-weight: 600; cursor: pointer; }
  .chapter-intro details p { margin-top: 8px; }

  /* ── STANDARD CARD ── */
  .standard { border: 1px solid var(--gray-200); border-top: none; background: #fff; }
  .standard:last-child { border-radius: 0 0 var(--radius) var(--radius); }
  .standard.fundamental { border-left: 4px solid var(--teal); }
  .standard-header { display: flex; align-items: center; gap: 12px; padding: 14px 20px; cursor: pointer; user-select: none; transition: background .12s; }
  .standard-header:hover { background: var(--gray-50); }
  .std-num { font-weight: 800; color: var(--teal); font-size: 1rem; min-width: 38px; }
  .std-title { font-weight: 600; flex: 1; }
  .f-badge { background: var(--teal); color: #fff; border-radius: 12px; padding: 2px 10px; font-size: .72rem; font-weight: 700; white-space: nowrap; }
  .chevron { color: var(--gray-400); font-size: 1.1rem; transition: transform .2s; margin-left: 6px; }
  .standard-header[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  /* ── STANDARD BODY ── */
  .standard-body { display: none; padding: 0 20px 20px; border-top: 1px solid var(--gray-200); }
  .standard-body.open { display: block; }
  .standard-text { font-size: .9rem; color: var(--gray-600); margin: 14px 0 10px; line-height: 1.7; }
  .section-label { font-weight: 700; font-size: .8rem; text-transform: uppercase; letter-spacing: .06em; color: var(--teal-dark); margin: 16px 0 8px; }
  .eoc-list { list-style: none; padding: 0; }
  .eoc-list li { padding: 7px 0 7px 20px; border-bottom: 1px solid var(--gray-100); font-size: .88rem; position: relative; line-height: 1.6; }
  .eoc-list li::before { content: '•'; position: absolute; left: 4px; color: var(--teal); font-weight: 900; }
  .eoc-list li:last-child { border-bottom: none; }
  .sub-list { list-style: none; padding: 0; margin: 6px 0 0 16px; }
  .sub-list li { padding: 4px 0 4px 16px; font-size: .85rem; color: var(--gray-600); position: relative; }
  .sub-list li::before { content: '–'; position: absolute; left: 0; color: var(--gold); }

  /* ── RUBRIC ── */
  .rubric-box { background: var(--gold-light); border: 1px solid #e8c06a; border-radius: var(--radius); padding: 14px 16px; margin-top: 12px; }
  .rubric-box .section-label { color: #8a6500; margin-top: 0; }
  .rubric-list { list-style: none; padding: 0; margin: 0; }
  .rubric-list li { padding: 6px 0 6px 20px; font-size: .86rem; border-bottom: 1px solid #f0d98a; position: relative; }
  .rubric-list li:last-child { border-bottom: none; }
  .rubric-list li::before { content: '?'; position: absolute; left: 2px; color: var(--gold); font-weight: 900; font-size: .8rem; }

  /* ── PRE-ASSESSMENT SECTION ── */
  .pre-assessment { background: #fff; border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 24px; margin-bottom: 32px; }
  .pre-assessment h3 { color: var(--teal-dark); font-size: 1rem; margin-bottom: 8px; }
  .pre-assessment p { font-size: .88rem; color: var(--gray-600); margin-bottom: 12px; }
  .pa-section { border: 1px solid var(--gray-200); border-radius: 6px; margin-bottom: 10px; overflow: hidden; }
  .pa-section summary { font-weight: 600; padding: 10px 14px; cursor: pointer; background: var(--gray-50); font-size: .9rem; }
  .pa-section summary:hover { background: var(--teal-light); }
  .pa-section .pa-body { padding: 12px 16px; font-size: .87rem; color: var(--gray-600); }

  /* ── PROCESS / OVERVIEW ── */
  .overview-box { background: #fff; border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 22px; margin-bottom: 32px; }
  .overview-box h3 { color: var(--teal-dark); margin-bottom: 10px; }
  .fund-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 8px; margin-top: 12px; }
  .fund-item { background: var(--fund-bg); border: 1px solid var(--fund-border); border-radius: 6px; padding: 6px 12px; font-size: .83rem; font-weight: 600; color: var(--teal-dark); }
  .stat-row { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 16px; }
  .stat { background: var(--teal-light); border-radius: var(--radius); padding: 10px 18px; text-align: center; }
  .stat .n { font-size: 1.6rem; font-weight: 800; color: var(--teal); }
  .stat .l { font-size: .75rem; color: var(--teal-dark); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }

  /* ── HIDDEN / SEARCH ── */
  .hidden { display: none !important; }

  /* ── PRINT ── */
  @media print {
    nav, .search-bar, header .header-meta { display: none; }
    .standard-body { display: block !important; }
    .chevron { display: none; }
    .chapter { page-break-inside: avoid; }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    header h1 { font-size: 1.3rem; }
    nav ul li a { padding: 10px 9px; font-size: .77rem; }
    .standard-header { padding: 11px 14px; }
    .standard-body { padding: 0 14px 16px; }
  }
</style>
</head>
